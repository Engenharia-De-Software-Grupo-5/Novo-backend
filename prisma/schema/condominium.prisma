model PropertyFiles {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  link String
  type String
  name String

  propertyId String     @db.Uuid
  property   Properties @relation(fields: [propertyId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("propertyfiles")
}
