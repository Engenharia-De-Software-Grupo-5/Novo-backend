model Condominiums {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String              @unique
  description       String?
  address           Addresses           @relation(fields: [addressId], references: [id])
  addressId         String              @db.Uuid
  properties        Properties[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  expenses          Expenses[]
  accesses          Access[]
  tenants           Tenants[]
  contractTemplates ContractTemplates[]
  employees         Employees[]
  employeeContracts EmployeeContracts[]

  @@map("condominiums")
}

model Addresses {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  zip              String
  street           String
  neighborhood     String
  city             String
  uf               String
  number           Int
  complement       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  professionalInfo ProfessionalInfo[]
  condominiums     Condominiums[]

  @@map("addresses")
}

model PropertyAddress {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  zip          String
  street       String
  neighborhood String
  city         String
  uf           String
  number       Int
  totalArea    Float?
  block        String?
  floor        Int?
  complement   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  properties   Properties[]

  @@map("propertyaddress")
}

model Properties {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier        String            @unique
  propertyAddress   PropertyAddress   @relation(fields: [propertyAddressId], references: [id])
  unityNumber       String
  unityType         UnityType         @default(APARTMENT)
  block             String?
  floor             Int?
  name              String
  totalArea         Float?
  propertySituation PropertySituation @default(ACTIVE)
  observations      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  condominium       Condominiums?     @relation(fields: [condominiumId], references: [id])
  condominiumId     String?           @db.Uuid
  expenses          Expenses[]
  contracts         Contracts[]
  files             PropertyFiles[]
  charges           Charges[]
  propertyAddressId String            @db.Uuid
  @@map("properties")
}

enum UnityType {
  HOUSE
  APARTMENT
  COMMERCIAL_ROOM
}

enum PropertySituation {
  ACTIVE
  INACTIVE
  UNAVAILABLE
  MAINTENANCE
}

