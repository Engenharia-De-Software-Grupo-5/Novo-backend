model Condominios {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome        String    @unique
  descricao   String?
  endereco    Enderecos @relation(fields: [enderecosId], references: [id])
  enderecosId String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("condominios")
}

model Enderecos {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cep         String
  rua         String
  bairro      String
  cidade      String
  uf          String
  numero      Int
  complemento String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  condominios Condominios[]

  @@map("enderecos")
}
