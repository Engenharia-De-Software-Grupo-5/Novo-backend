model Condominios {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome        String    @unique
  descricao   String?
  endereco    Enderecos @relation(fields: [enderecosId], references: [id])
  enderecosId String    @db.Uuid
  imovel Imoveis[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("condominios")
}

model Enderecos {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cep         String
  rua         String
  bairro      String
  cidade      String
  uf          String
  numero      Int
  complemento String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  condominios Condominios[]

  @@map("enderecos")
}

model Imoveis {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identificador String
  endereco      String
  numeroUnidade String
  tipoUnidade   TipoUnidade @default(APARTAMENTO)
  bloco         String?
  andar         Int?
  areaTotal     Float?
  situacao      SituacaoImovel   @default(ATIVO)
  observacoes      String?
  condominioId   String @db.Uuid
  condominio     Condominios @relation(fields: [condominioId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@map("imoveis")
}

enum TipoUnidade {
  CASA
  APARTAMENTO
  SALA_COMERCIAL
}

enum SituacaoImovel {
  ATIVO
  INATIVO
  INDISPONIVEL
  MANUTENCAO
}
