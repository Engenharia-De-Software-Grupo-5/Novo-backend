model Invoices {
    id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

    objectName   String @unique
    originalName String
    mimeType     String
    extension    String
    size         Int

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@map("invoices")
}
