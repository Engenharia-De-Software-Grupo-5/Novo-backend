enum ContractType {
  CLT
  PJ
  TEMPORARY
  INTERNSHIP
  OUTSOURCED
}

enum EmployeeStatus {
  ATIVO
  INATIVO
  PENDENTE
}

enum EmployeeRoles {
  GERENTE
  PORTEIRO
  ZELADOR
  FAXINEIRO
}

model Employees {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cpf               String              @unique
  name              String
  email             String?
  bankDataId        String?              @unique @db.Uuid
  bankData          BanksData?           @relation(fields: [bankDataId], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  role              EmployeeRoles
  contractType      ContractType?
  admissionDate     DateTime?
  birthDate         DateTime
  address           String?
  phone             String?
  terminationDate   DateTime?
  baseSalary        Float?
  workload          Int?
  status            EmployeeStatus      @default(ATIVO)
  employeeContracts EmployeeContracts[]
  employeePayments  EmployeePayments[]
  employeeBenefits  EmployeeBenefits[]

  @@map("employees")
}

model BanksData {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  bank          String
  accountType   String
  accountNumber String
  agency        String

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  employees     Employees?

  @@map("banksdata")
}

model EmployeeContracts {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  employeeId String    @db.Uuid
  employee   Employees @relation(fields: [employeeId], references: [id])

  objectName   String @unique
  originalName String
  mimeType     String
  extension    String
  size         Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("employee_contracts")
}

enum PaymentType {
  SALARY
  BONUS
  ADVANCE
  OTHER
}

model EmployeePayments {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  employeeId String    @db.Uuid
  employee   Employees @relation(fields: [employeeId], references: [id])

  value       Float
  paymentDate DateTime
  type        PaymentType

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("employee_payments")
}

enum BenefitType {
  VACATION
  THIRTEENTH
}

model EmployeeBenefits {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  employeeId String    @db.Uuid
  employee   Employees @relation(fields: [employeeId], references: [id])

  type          BenefitType
  referenceYear Int
  value         Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("employee_benefits")
}
