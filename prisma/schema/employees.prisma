enum ContractType {
  CLT
  PJ
  TEMPORARY
  INTERNSHIP
  OUTSOURCED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
  VACATION
}

model Employees {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cpf                   String                  @unique
  name                  String
  bankData              BanksData               @relation(fields: [bankDataId], references: [id])
  bankDataId            String                  @db.Uuid
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  deletedAt             DateTime?
  role                  String
  contractType          ContractType
  hireDate              DateTime
  terminationDate       DateTime?
  baseSalary            Float
  workload              Int
  status                EmployeeStatus          @default(ACTIVE)
  employeePayments      EmployeePayments[]
  employeeBenefits      EmployeeBenefits[]
  employeeContractLinks EmployeeContractLinks[]

  @@map("employees")
}

model BanksData {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?
  employees Employees[]

  @@map("banksdata")
}

enum PaymentType {
  SALARY
  BONUS
  ADVANCE
  OTHER
}

model EmployeePayments {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  employeeId String    @db.Uuid
  employee   Employees @relation(fields: [employeeId], references: [id])

  value       Float
  paymentDate DateTime
  type        PaymentType

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("employee_payments")
}

enum BenefitType {
  VACATION
  THIRTEENTH
}

model EmployeeBenefits {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  employeeId String    @db.Uuid
  employee   Employees @relation(fields: [employeeId], references: [id])

  type          BenefitType
  referenceYear Int
  value         Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("employee_benefits")
}
