model Users {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String      @unique
  cpf           String      @unique
  name          String
  password      String
  permission    Permissions @relation(fields: [permissionsId], references: [id])
  permissionsId String      @db.Uuid
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  @@map("users")
}

model Permissions {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String    @unique
  functionalities String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  users           Users[]

  @@map("permissions")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
