model Users {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  name          String
  password      String
  isAdminMaster Boolean   @default(false)
  inviteDate    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  accesses      Access[]

  @@map("users")
}

model Permissions {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String    @unique
  functionalities String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  accesses        Access[]

  @@map("permissions")
}

model Access {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user           Users        @relation(fields: [usersId], references: [id])
  usersId        String       @db.Uuid
  permission     Permissions  @relation(fields: [permissionsId], references: [id])
  condominium    Condominiums @relation(fields: [condominiumsId], references: [id])
  permissionsId  String       @db.Uuid
  condominiumsId String       @db.Uuid
  status         UserStatus   @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([usersId, condominiumsId])
  @@map("access")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
