enum ExpenseTargetType {
  CONDOMINIUM
  PROPERTY
}

enum ExpensePaymentMethod {
  CASH
  PIX
  BOLETO
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
  OTHER
}

model ExpensesFiles {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  link       String
  type       String?
  expenses   Expenses? @relation(fields: [expensesId], references: [id])
  expensesId String?   @db.Uuid
}

model Expenses {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  description String
  targetType  ExpenseTargetType

  condominiumId String? @db.Uuid
  propertyId    String? @db.Uuid

  condominium Condominiums? @relation(fields: [condominiumId], references: [id])
  property    Properties?   @relation(fields: [propertyId], references: [id])

  expenseType   String
  value         Float
  expenseDate   DateTime
  paymentMethod ExpensePaymentMethod

  expenseFiles ExpensesFiles[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  // invoices  Invoices[]

  @@map("expenses")
}

model Invoices {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  expenseId String   @db.Uuid
  // expense   Expenses @relation(fields: [expenseId], references: [id])

  objectName   String @unique
  originalName String
  mimeType     String
  size         Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("invoices")
}
