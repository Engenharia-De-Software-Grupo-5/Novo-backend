model ContractTemplates {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String       @unique
  description   String?
  template      String       @db.Text
  condominium   Condominiums @relation(fields: [condominiumId], references: [id])
  condominiumId String       @db.Uuid
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  contract      Contracts[]

  @@map("contracttemplates")
}
