model Users {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String      @unique
  cpf           String?     @unique
  name          String
  password      String
  permission    Permissions @relation(fields: [permissionsId], references: [id])
  permissionsId String      @db.Uuid
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  @@map("users")
}

model Permissions {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String    @unique
  functionalities String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  users           Users[]

  @@map("permissions")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

enum PaymentMethod {
  BOLETO
  PIX
  DEPOSIT
}

model Charges {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  tenantId   String @db.Uuid
  propertyId String @db.Uuid

  amount  Float
  dueDate DateTime

  fineRate      Float         @default(2)
  monthlyRate   Float         @default(1)
  paymentMethod PaymentMethod

  status ChargeStatus @default(PENDING)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant   Tenants    @relation(fields: [tenantId], references: [id])
  property Properties @relation(fields: [propertyId], references: [id])

  payments Payments[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([dueDate])
}

model Payments {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chargeId String @db.Uuid

  amountPaid  Float
  paymentDate DateTime
  method      PaymentMethod

  wasLate  Boolean
  daysLate Int

  fineRate     Float
  monthlyRate  Float
  finePaid     Float
  interestPaid Float
  totalPaid    Float

  proofObjectName   String?
  proofOriginalName String?
  proofMimeType     String?
  proofExtension    String?
  proofSize         Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  charge Charges @relation(fields: [chargeId], references: [id])

  @@index([chargeId])
  @@index([paymentDate])
}

model Condominiums {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique
  description String?
  address     Addresses    @relation(fields: [addressId], references: [id])
  addressId   String       @db.Uuid
  properties  Properties[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  expenses    Expenses[]

  @@map("condominiums")
}

model Addresses {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  zip              String
  street           String
  neighborhood     String
  city             String
  uf               String
  number           Int
  complement       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  condominiums     Condominiums[]
  tenants          Tenants[]
  professionalInfo ProfessionalInfo[]

  @@map("addresses")
}

model Properties {
  id                          String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier                  String                        @unique
  address                     String
  unityNumber                 String
  unityType                   UnityType                     @default(APARTMENT)
  block                       String?
  floor                       Int?
  totalArea                   Float?
  propertySituation           PropertySituation             @default(ACTIVE)
  observations                String?
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  deletedAt                   DateTime?
  condominium                 Condominiums?                 @relation(fields: [condominiumId], references: [id])
  condominiumId               String?                       @db.Uuid
  expenses                    Expenses[]
  inspections                 PropertyInspections[]
  documents                   PropertyDocuments[]
  propertyTenantContractLinks PropertyTenantContractLinks[]
  charges                     Charges[]

  @@map("properties")
}

enum UnityType {
  HOUSE
  APARTMENT
  COMMERCIAL_ROOM
}

enum PropertySituation {
  ACTIVE
  INACTIVE
  UNAVAILABLE
  MAINTENANCE
}

model PropertyInspections {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  propertyId String     @db.Uuid
  property   Properties @relation(fields: [propertyId], references: [id])

  objectName   String @unique
  originalName String
  mimeType     String
  extension    String
  size         Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("property_inspections")
}

model PropertyDocuments {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  propertyId String     @db.Uuid
  property   Properties @relation(fields: [propertyId], references: [id])

  objectName   String @unique
  originalName String
  mimeType     String
  extension    String
  size         Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("property_documents")
}

model ContractTemplates {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique
  description String?
  template    String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("contracttemplates")
}

model Contracts {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  objectName   String @unique
  originalName String
  mimeType     String
  extension    String
  size         Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  leases PropertyTenantContractLinks[]

  @@map("contracts")
}

model PropertyTenantContractLinks {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  contractId String    @db.Uuid
  contract   Contracts @relation(fields: [contractId], references: [id])

  propertyId String     @db.Uuid
  property   Properties @relation(fields: [propertyId], references: [id])

  tenantId String  @db.Uuid
  tenant   Tenants @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@unique([contractId, propertyId, tenantId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([contractId])
  @@map("property_tenant_contract_links")
}

enum ContractType {
  CLT
  PJ
  TEMPORARY
  INTERNSHIP
  OUTSOURCED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
  VACATION
}

model Employees {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cpf               String              @unique
  name              String
  bankData          BanksData           @relation(fields: [bankDataId], references: [id])
  bankDataId        String              @db.Uuid
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  role              String
  contractType      ContractType
  hireDate          DateTime
  terminationDate   DateTime?
  baseSalary        Float
  workload          Int
  status            EmployeeStatus      @default(ACTIVE)
  employeeContracts EmployeeContracts[]
  employeePayments  EmployeePayments[]
  employeeBenefits  EmployeeBenefits[]

  @@map("employees")
}

model BanksData {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?
  employees Employees[]

  @@map("banksdata")
}

model EmployeeContracts {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  employeeId String    @db.Uuid
  employee   Employees @relation(fields: [employeeId], references: [id])

  objectName   String @unique
  originalName String
  mimeType     String
  extension    String
  size         Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("employee_contracts")
}

enum PaymentType {
  SALARY
  BONUS
  ADVANCE
  OTHER
}

model EmployeePayments {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  employeeId String    @db.Uuid
  employee   Employees @relation(fields: [employeeId], references: [id])

  value       Float
  paymentDate DateTime
  type        PaymentType

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("employee_payments")
}

enum BenefitType {
  VACATION
  THIRTEENTH
}

model EmployeeBenefits {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  employeeId String    @db.Uuid
  employee   Employees @relation(fields: [employeeId], references: [id])

  type          BenefitType
  referenceYear Int
  value         Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("employee_benefits")
}

enum ExpenseTargetType {
  CONDOMINIUM
  PROPERTY
}

enum ExpensePaymentMethod {
  CASH
  PIX
  BOLETO
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
  OTHER
}

model Expenses {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  targetType ExpenseTargetType

  condominiumId String? @db.Uuid
  propertyId    String? @db.Uuid

  condominium Condominiums? @relation(fields: [condominiumId], references: [id])
  property    Properties?   @relation(fields: [propertyId], references: [id])

  expenseType   String
  value         Float
  expenseDate   DateTime
  paymentMethod ExpensePaymentMethod

  invoices Invoices[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("expenses")
}

model Invoices {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  expenseId String   @db.Uuid
  expense   Expenses @relation(fields: [expenseId], references: [id])

  objectName   String @unique
  originalName String
  mimeType     String
  extension    String
  size         Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("invoices")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "views"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

model Tenants {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cpf       String    @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  birthDate      DateTime
  maritalStatus  String
  monthlyIncome  Float
  email          String
  primaryPhone   String
  secondaryPhone String?
  addressId      String    @db.Uuid
  address        Addresses @relation(fields: [addressId], references: [id])

  condominiumId String

  emergencyContacts   EmergencyContact[]
  professionalInfo    ProfessionalInfo?
  bankingInfo         BankingInfo?
  spouse              Spouse?
  additionalResidents AdditionalResident[]
  documents           TenantDocument?
  propertyLinks       PropertyTenantContractLinks[]
  charges             Charges[]

  status TenantStatus

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  PENDING
}

model EmergencyContact {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  relationship String?
  phone        String

  tenantId String  @db.Uuid
  tenant   Tenants @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("emergency_contacts")
}

model ProfessionalInfo {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName    String
  companyPhone   String
  addressId      String    @db.Uuid
  companyAddress Addresses @relation(fields: [addressId], references: [id])
  position       String
  monthsWorking  Int

  tenantId String  @unique @db.Uuid
  tenant   Tenants @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("professional_info")
}

model BankingInfo {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bank          String
  accountType   String
  accountNumber String
  agency        String

  tenantId String  @unique @db.Uuid
  tenant   Tenants @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("banking_info")
}

model Spouse {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  cpf           String
  profession    String
  monthlyIncome Float
  birthDate     DateTime

  tenantId String  @unique @db.Uuid
  tenant   Tenants @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("spouses")
}

model AdditionalResident {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  relationship String?
  birthDate    DateTime

  tenantId String  @db.Uuid
  tenant   Tenants @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("additional_residents")
}

model TenantDocument {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cpfFileId     String?
  incomeProofId String?

  tenantId String  @unique @db.Uuid
  tenant   Tenants @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("tenant_documents")
}
